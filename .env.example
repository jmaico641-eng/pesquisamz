# Variáveis de Ambiente para Serverless Functions
# Estas variáveis ficam NO LADO DO SERVIDOR e nunca são expostas ao cliente

# ═══════════════════════════════════════════
# GROQ API
# Obter em: https://console.groq.com/keys
# ═══════════════════════════════════════════
GROQ_API_KEY=sua_chave_groq_aqui

# ═══════════════════════════════════════════
# ANTHROPIC API
# Obter em: https://console.anthropic.com/settings/keys
# ═══════════════════════════════════════════
ANTHROPIC_API_KEY=sua_chave_anthropic_aqui
ANTHROPIC_VERSION=2023-06-01

# ═══════════════════════════════════════════
# PROTEÇÃO ADICIONAL (OPCIONAL)
# Se quiseres proteger as funções serverless
# com uma chave extra, define isto e adiciona
# o mesmo valor no frontend
# ═══════════════════════════════════════════
# API_SECRET=tua_secret_key_aqui

# ═══════════════════════════════════════════
# FIREBASE (SE USAR)
# ═══════════════════════════════════════════
# FIREBASE_API_KEY=sua_firebase_key
# FIREBASE_PROJECT_ID=seu_project_id
